{
  "schema_version": "1.0",
  "name": "surrogate_kinetic_segregation_sbi",
  "kind": "conditional",
  "inputs": ["time_sec", "rigidity_kT_nm2"],
  "outputs": ["depletion_width_nm"],
  "backend": "sbi_npe",
  "backend_config": {
    "density_estimator": "maf",
    "max_num_epochs": 120,
    "training_batch_size": 32,
    "learning_rate": 0.0005,
    "stop_after_epochs": 20,
    "summary_samples": 256
  },
  "dataset_ref": "projects/tcr_signaling/store",
  "seed": 42
}
